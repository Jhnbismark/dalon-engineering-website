---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/base';

const directors = [
  {
    initials: 'OJ',
    name: 'Ondoga John Bismark',
    role: 'Managing Director',
    bio: 'A civil engineer by profession, John leads the company’s technical direction and overall operations. He is responsible for engineering quality across all engagements — from design and costing through to site delivery — and is the principal point of contact for clients and partners.',
  },
  {
    initials: 'AG',
    name: 'Alumai Gasper Drichi',
    role: 'Director & Company Secretary',
    bio: 'A telecommunication engineer by profession, Gasper oversees corporate governance, administration and compliance. He manages the company’s statutory affairs and supports project delivery on the commercial and technology side, ensuring every engagement is properly documented, contracted and accounted for.',
  },
];

const values = [
  {
    title: 'Integrity',
    text: 'We give honest advice, quote real costs and build exactly what we promise. Our reputation is the foundation everything else stands on.',
  },
  {
    title: 'Precision',
    text: 'Engineering rewards care. We measure twice, document thoroughly and hold our work to the standards we would demand as clients.',
  },
  {
    title: 'Accountability',
    text: 'One firm, one signature, one point of responsibility. When we take on a project, its success becomes our problem to solve.',
  },
];
---

<Base
  title="About Us — Dalon Engineering Company Limited"
  description="Learn about Dalon Engineering Company Limited — a newly registered Ugandan engineering firm in Kampala led by civil engineer Ondoga John Bismark and director Alumai Gasper Drichi."
>
  <!-- ============ PAGE HEADER ============ -->
  <section class="page-head">
    <div class="grid-texture" aria-hidden="true"></div>
    <span class="ghost-word" aria-hidden="true">DALON</span>
    <div class="container page-head-content">
      <p class="eyebrow">About us</p>
      <h1 class="section-title page-title">
        Built by engineers.<br />Run on <em>principle.</em>
      </h1>
      <p class="lede">
        Dalon Engineering Company Limited is a newly registered Ugandan
        engineering company headquartered in Kampala, founded to deliver
        construction and engineering services the way they should be
        delivered — competently, transparently and on time.
      </p>
    </div>
  </section>

  <!-- ============ OVERVIEW ============ -->
  <section class="section section--line">
    <div class="container overview">
      <div class="reveal">
        <p class="eyebrow">The company</p>
        <h2 class="section-title">One roof, full delivery.</h2>
      </div>
      <div class="overview-copy reveal" style="--reveal-delay: 0.15s">
        <p>
          We offer construction works, engineering consultancy, project
          management, quantity surveying, real estate development, material
          supply and plant hire. Holding these capabilities together means a
          client’s project does not get fragmented across firms that don’t
          talk to each other — design decisions account for cost, cost
          decisions account for buildability, and one team answers for the
          result.
        </p>
        <p>
          We are new, and we treat that as an advantage: no legacy shortcuts,
          no inherited habits. Every project we take on is an opportunity to
          prove a simple proposition — that a Ugandan firm can deliver
          engineering work to an uncompromising standard.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ MISSION / VISION ============ -->
  <section class="section section--line mv">
    <div class="diagonal-texture" aria-hidden="true"></div>
    <div class="container mv-grid">
      <div class="card mv-card reveal">
        <p class="eyebrow">Our mission</p>
        <p class="mv-text">
          To deliver reliable, high-quality engineering and construction
          services that create lasting value for our clients and communities
          across Uganda.
        </p>
      </div>
      <div class="card mv-card reveal" style="--reveal-delay: 0.15s">
        <p class="eyebrow">Our vision</p>
        <p class="mv-text">
          To become one of Uganda’s most trusted engineering companies — known
          for integrity, technical excellence and projects that stand the test
          of time.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ VALUES ============ -->
  <section class="section section--line">
    <div class="container">
      <div class="reveal">
        <p class="eyebrow">What we stand for</p>
        <h2 class="section-title">Values that hold weight.</h2>
      </div>
      <div class="values-grid">
        {
          values.map((value, i) => (
            <div class="value-item reveal" style={`--reveal-delay: ${i * 0.12}s`}>
              <span class="value-index">0{i + 1}</span>
              <h3 class="value-title">{value.title}</h3>
              <p class="value-text">{value.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ DIRECTORS ============ -->
  <section class="section section--line">
    <div class="container">
      <div class="reveal">
        <p class="eyebrow">Leadership</p>
        <h2 class="section-title">The directors.</h2>
      </div>
      <div class="directors-grid">
        {
          directors.map((director, i) => (
            <article class="card director-card reveal" style={`--reveal-delay: ${i * 0.15}s`}>
              <div class="director-monogram" aria-hidden="true">
                {director.initials}
              </div>
              <div>
                <h3 class="director-name">{director.name}</h3>
                <p class="director-role">{director.role}</p>
                <p class="director-bio">{director.bio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="section cta-band">
    <div class="container cta-inner reveal">
      <h2 class="section-title">Work with us.</h2>
      <p class="lede cta-lede">
        We would be glad to discuss your project, however early the idea.
      </p>
      <a href={withBase('/contact/')} class="btn btn--gold">
        Get in touch
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h11M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" />
        </svg>
      </a>
    </div>
  </section>
</Base>

<style>
  .page-head {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4.5rem, 10vw, 7.5rem);
  }

  .page-head-content {
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
  }

  /* overview */
  .overview {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: 3.5rem;
    align-items: start;
  }

  .overview-copy {
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding-top: 0.5rem;
  }

  @media (max-width: 820px) {
    .overview {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* mission / vision */
  .mv {
    overflow: hidden;
  }

  .mv .diagonal-texture {
    opacity: 0.3;
  }

  .mv-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .mv-card {
    padding: 2.6rem 2.4rem;
  }

  .mv-text {
    margin-top: 1.4rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--text);
  }

  @media (max-width: 720px) {
    .mv-grid {
      grid-template-columns: 1fr;
    }
  }

  /* values */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .value-item {
    border-top: 1px solid var(--line);
    padding-top: 1.6rem;
  }

  .value-index {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.1em;
  }

  .value-title {
    font-size: 1.25rem;
    margin-top: 0.8rem;
  }

  .value-text {
    color: var(--muted);
    font-size: 0.94rem;
    margin-top: 0.8rem;
  }

  @media (max-width: 720px) {
    .values-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* directors */
  .directors-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .director-card {
    display: flex;
    gap: 1.8rem;
    align-items: flex-start;
    padding: 2.4rem 2.2rem;
  }

  .director-monogram {
    flex-shrink: 0;
    width: 4.6rem;
    height: 4.6rem;
    display: grid;
    place-items: center;
    border: 1px solid transparent;
    background:
      linear-gradient(150deg, rgba(200, 169, 110, 0.14), var(--ink-2) 75%) padding-box,
      linear-gradient(150deg, var(--gold), rgba(200, 169, 110, 0.1)) border-box;
    color: var(--gold-bright);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: 0.05em;
    transition: transform 0.45s var(--ease-fluid);
  }

  .director-card:hover .director-monogram {
    transform: rotate(-4deg) scale(1.04);
  }

  .director-name {
    font-size: 1.2rem;
  }

  .director-role {
    margin-top: 0.35rem;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .director-bio {
    margin-top: 1rem;
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 820px) {
    .directors-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .director-card {
      flex-direction: column;
    }
  }

  /* cta */
  .cta-band {
    border-top: 1px solid var(--line-faint);
    background:
      radial-gradient(ellipse 55% 70% at 50% 100%, rgba(200, 169, 110, 0.08), transparent 70%),
      var(--ink-2);
  }

  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-lede {
    margin-top: 1.2rem;
    margin-bottom: 2.2rem;
  }
</style>
