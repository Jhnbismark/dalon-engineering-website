---
import Base from '../layouts/Base.astro';
import { services } from '../data/services';
import { withBase } from '../lib/base';

const heroFacts = [
  { label: 'Registered', value: 'Republic of Uganda' },
  { label: 'Leadership', value: 'Engineer-led' },
  { label: 'Based in', value: 'Kampala' },
  { label: 'Coverage', value: 'Full project lifecycle' },
];
---

<Base
  title="Dalon Engineering Company Limited — Construction & Engineering, Kampala, Uganda"
  description="Dalon Engineering Company Limited is a Ugandan engineering firm offering construction works, engineering consultancy, project management, quantity surveying, real estate development, material supply and plant hire in Kampala and across Uganda."
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="grid-texture" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="eyebrow hero-anim" style="--anim-delay: 0s">
          Kampala · Uganda
        </p>
        <h1 class="hero-title hero-anim" style="--anim-delay: 0.12s">
          Engineering built on <em class="title-accent">integrity.</em><br />
          Delivered with <em class="title-accent">precision.</em>
        </h1>
        <p class="hero-lede hero-anim" style="--anim-delay: 0.24s">
          Dalon Engineering Company Limited is a Ugandan engineering firm
          providing construction, consultancy and development services — led by
          qualified engineers who stand behind every structure we touch.
        </p>
        <div class="hero-actions hero-anim" style="--anim-delay: 0.36s">
          <a href={withBase('/contact/')} class="btn btn--gold">
            Start a project
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h11M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
          <a href={withBase('/services/')} class="btn btn--ghost">Explore services</a>
        </div>

        <dl class="hero-facts hero-anim" style="--anim-delay: 0.5s">
          {
            heroFacts.map((fact) => (
              <div class="hero-fact">
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <!-- Architectural line work, echoing the logo geometry -->
      <div class="hero-art hero-anim" style="--anim-delay: 0.3s" aria-hidden="true">
        <svg viewBox="0 0 420 460" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <clipPath id="hero-tower">
              <path d="M40 440 V190 L170 80 V440 Z"></path>
            </clipPath>
            <linearGradient id="hero-fade" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#e3c990" stop-opacity="0.95"></stop>
              <stop offset="1" stop-color="#c8a96e" stop-opacity="0.2"></stop>
            </linearGradient>
          </defs>
          <g clip-path="url(#hero-tower)" stroke="url(#hero-fade)" stroke-width="10">
            <line x1="-80" y1="380" x2="280" y2="60"></line>
            <line x1="-50" y1="410" x2="310" y2="90"></line>
            <line x1="-20" y1="440" x2="340" y2="120"></line>
            <line x1="10" y1="470" x2="370" y2="150"></line>
            <line x1="40" y1="500" x2="400" y2="180"></line>
            <line x1="70" y1="530" x2="430" y2="210"></line>
            <line x1="100" y1="560" x2="460" y2="240"></line>
          </g>
          <rect x="196" y="118" width="18" height="322" fill="url(#hero-fade)"></rect>
          <rect x="238" y="152" width="18" height="288" fill="url(#hero-fade)"></rect>
          <rect x="280" y="186" width="18" height="254" fill="url(#hero-fade)"></rect>
          <rect x="318" y="220" width="18" height="220" fill="url(#hero-fade)"></rect>
          <line x1="0" y1="440.5" x2="420" y2="440.5" stroke="#c8a96e" stroke-opacity="0.5"></line>
          <line x1="0" y1="446.5" x2="420" y2="446.5" stroke="#c8a96e" stroke-opacity="0.15"></line>
        </svg>
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE ============ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {services.map((s) => <span class="marquee-item">{s.title}</span>)}
    </div>
    <div class="marquee-track" aria-hidden="true">
      {services.map((s) => <span class="marquee-item">{s.title}</span>)}
    </div>
  </div>

  <!-- ============ SERVICES ============ -->
  <section class="section services">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <p class="eyebrow">What we do</p>
          <h2 class="section-title">Six disciplines.<br />One <em>standard</em> of work.</h2>
        </div>
        <a href={withBase('/services/')} class="btn btn--ghost section-head-cta">
          All services
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h11M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" />
          </svg>
        </a>
      </div>

      <div class="services-grid">
        {
          services.map((service, i) => (
            <a
              href={withBase(`/services/#${service.id}`)}
              class="card service-card reveal"
              style={`--reveal-delay: ${(i % 3) * 0.12}s`}
            >
              <span class="service-index" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="icon-chip">
                <svg
                  class="service-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={service.icon} />
                </svg>
              </span>
              <h3 class="service-title">{service.title}</h3>
              <p class="service-blurb">{service.blurb}</p>
              <span class="service-more">
                Learn more
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h11M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ INTRO ============ -->
  <section class="section section--line intro">
    <div class="diagonal-texture" aria-hidden="true"></div>
    <div
      class="intro-watermark"
      style={`background-image: url(${withBase('/logo-gold.png')})`}
      aria-hidden="true"
    >
    </div>
    <div class="container intro-inner">
      <div class="reveal">
        <p class="eyebrow">Who we are</p>
        <h2 class="section-title">
          A new firm with an old-fashioned belief: <em>do the work properly.</em>
        </h2>
      </div>
      <div class="intro-copy reveal" style="--reveal-delay: 0.15s">
        <p>
          Dalon Engineering Company Limited is a newly registered Ugandan
          company founded by practising engineers. We combine technical design
          capability, cost discipline and hands-on site delivery under one
          roof — so clients deal with one accountable partner instead of a
          chain of middlemen.
        </p>
        <p>
          Whether you are building a home, developing property or procuring
          works for an institution, we bring the same approach: honest advice,
          careful engineering and a finished product we are proud to sign.
        </p>
        <a href={withBase('/about/')} class="btn btn--ghost">About the company</a>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="section cta">
    <div class="container">
      <div class="cta-frame reveal">
        <span class="cta-corner cta-corner--tl" aria-hidden="true"></span>
        <span class="cta-corner cta-corner--br" aria-hidden="true"></span>
        <h2 class="cta-title">Have a project in <em class="title-accent">mind?</em></h2>
        <p class="cta-lede">
          Tell us what you want to build. We will respond with clear, practical
          next steps — no obligation.
        </p>
        <a href={withBase('/contact/')} class="btn btn--gold">
          Contact us
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h11M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---- hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(5rem, 12vw, 9rem) clamp(4.5rem, 10vw, 7.5rem);
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 45% at 78% 18%, rgba(200, 169, 110, 0.1), transparent 70%),
      radial-gradient(ellipse 40% 35% at 12% 85%, rgba(200, 169, 110, 0.05), transparent 70%);
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.85fr);
    align-items: center;
    gap: 3rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5.9vw, 4.4rem);
    margin-top: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero-lede {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 34rem;
    margin-top: 1.7rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .hero-facts {
    display: grid;
    grid-template-columns: repeat(4, auto);
    justify-content: start;
    gap: 2.75rem;
    margin: 3.4rem 0 0;
    padding-top: 1.9rem;
    border-top: 1px solid var(--line-faint);
  }

  .hero-fact dt {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .hero-fact dd {
    margin: 0.4rem 0 0;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }

  .hero-art {
    animation: hero-float 9s ease-in-out infinite alternate;
  }

  .hero-art svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 24px 60px rgba(200, 169, 110, 0.12));
  }

  @keyframes hero-float {
    to {
      transform: translateY(-14px);
    }
  }

  .hero-anim {
    opacity: 0;
    transform: translateY(28px);
    animation: hero-rise 1s var(--ease-fluid) forwards;
    animation-delay: var(--anim-delay, 0s);
  }

  @keyframes hero-rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* hero-art floats AND rises: nest animations on separate elements */
  .hero-art.hero-anim {
    animation:
      hero-rise 1s var(--ease-fluid) forwards,
      hero-float 9s ease-in-out 1.4s infinite alternate;
    animation-delay: var(--anim-delay, 0s), 1.4s;
  }

  @media (max-width: 880px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-art {
      max-width: 18rem;
      justify-self: center;
      order: -1;
      opacity: 0.9;
    }

    .hero-facts {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.6rem 2rem;
    }
  }

  /* ---- section head ---- */
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .section-head-cta {
    flex-shrink: 0;
  }

  /* ---- services grid ---- */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3.4rem;
  }

  .service-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    cursor: pointer;
  }

  .service-index {
    position: absolute;
    top: 1.4rem;
    right: 1.6rem;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(200, 169, 110, 0.22);
    transition: -webkit-text-stroke-color 0.45s var(--ease-fluid);
  }

  .service-card:hover .service-index {
    -webkit-text-stroke-color: rgba(200, 169, 110, 0.55);
  }

  .service-icon {
    width: 1.7rem;
    height: 1.7rem;
  }

  .service-card:hover .icon-chip {
    background: linear-gradient(150deg, rgba(200, 169, 110, 0.22), rgba(200, 169, 110, 0.05) 70%);
    border-color: var(--gold-dim);
    color: var(--gold-bright);
  }

  .service-title {
    font-size: 1.14rem;
    margin: 1.5rem 0 0.7rem;
  }

  .service-blurb {
    color: var(--muted);
    font-size: 0.93rem;
    flex-grow: 1;
  }

  .service-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.6rem;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .service-more svg {
    transition: transform 0.4s var(--ease-fluid);
  }

  .service-card:hover .service-more svg {
    transform: translateX(4px);
  }

  @media (max-width: 920px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- intro ---- */
  .intro {
    overflow: hidden;
    background: var(--ink-2);
  }

  .intro .diagonal-texture {
    mask-image: linear-gradient(105deg, transparent 55%, black);
    -webkit-mask-image: linear-gradient(105deg, transparent 55%, black);
  }

  .intro-watermark {
    position: absolute;
    right: -6%;
    bottom: -12%;
    width: clamp(20rem, 42vw, 36rem);
    aspect-ratio: 811 / 298;
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    opacity: 0.05;
    pointer-events: none;
  }

  .intro-inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 3.5rem;
    align-items: start;
  }

  .intro-copy {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    align-items: flex-start;
    color: var(--muted);
    padding-top: 0.5rem;
  }

  .intro-copy .btn {
    margin-top: 0.6rem;
  }

  @media (max-width: 820px) {
    .intro-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ---- cta ---- */
  .cta {
    border-top: 1px solid var(--line-faint);
  }

  .cta-frame {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(3rem, 7vw, 5rem) clamp(1.5rem, 6vw, 5rem);
    border: 1px solid transparent;
    background:
      linear-gradient(165deg, var(--panel) 0%, var(--ink-2) 90%) padding-box,
      var(--border-grad) border-box;
  }

  .cta-corner {
    position: absolute;
    width: 2.6rem;
    height: 2.6rem;
    pointer-events: none;
  }

  .cta-corner--tl {
    top: -1px;
    left: -1px;
    border-top: 2px solid var(--gold);
    border-left: 2px solid var(--gold);
  }

  .cta-corner--br {
    bottom: -1px;
    right: -1px;
    border-bottom: 2px solid var(--gold);
    border-right: 2px solid var(--gold);
  }

  .cta-title {
    font-size: clamp(2rem, 4.6vw, 3.2rem);
  }

  .cta-lede {
    color: var(--muted);
    max-width: 30rem;
    margin-block: 1.2rem 2.2rem;
  }
</style>
