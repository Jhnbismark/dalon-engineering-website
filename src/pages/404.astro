---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/base';
---

<Base
  title="Page Not Found — Dalon Engineering Company Limited"
  description="The page you are looking for does not exist."
>
  <section class="section nf">
    <div class="grid-texture" aria-hidden="true"></div>
    <div class="container nf-inner">
      <p class="nf-code" aria-hidden="true">404</p>
      <h1 class="section-title">This page isn't on the drawings.</h1>
      <p class="lede nf-lede">
        The page you are looking for doesn't exist or has been moved.
      </p>
      <a href={withBase('/')} class="btn btn--gold">Back to home</a>
    </div>
  </section>
</Base>

<style>
  .nf {
    min-height: 60vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .nf-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .nf-code {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 7rem);
    font-weight: 800;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--gold-dim);
    margin-bottom: 1rem;
  }

  .nf-lede {
    margin-top: 1rem;
    margin-bottom: 2.2rem;
    max-width: none;
  }
</style>
