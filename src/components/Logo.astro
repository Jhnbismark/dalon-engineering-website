---
// The official Dalon lockup (from Dalonlogo.jpg), converted to a white
// transparent PNG by scripts/process-logo.mjs so it sits on dark surfaces.
import { withBase } from '../lib/base';

interface Props {
  /** Rendered height in rem units. Source is 811x298, so width scales. */
  size?: 'nav' | 'footer';
  class?: string;
}
const { size = 'nav', class: className } = Astro.props;
---

<a
  href={withBase('/')}
  class:list={['logo', `logo--${size}`, className]}
  aria-label="Dalon Engineering Company Limited — Home"
>
  <img
    src={withBase('/logo-white.png')}
    alt="DALON — Engineering Company Limited"
    width="811"
    height="298"
    loading="eager"
    decoding="async"
  />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.3s var(--ease-fluid);
  }

  .logo:hover {
    opacity: 0.85;
  }

  .logo img {
    width: auto;
    display: block;
  }

  .logo--nav img {
    height: 2.9rem;
  }

  .logo--footer img {
    height: 3.6rem;
  }

  @media (max-width: 480px) {
    .logo--nav img {
      height: 2.4rem;
    }
  }
</style>
